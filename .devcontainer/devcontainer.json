    // --- PHP ---
    // "ghcr.io/devcontainers/features/php:1": {
    //   "version": "latest",
    //   "installComposer": true
    // },

    // --- Ruby (via rvm) ---
    // "ghcr.io/devcontainers/features/ruby:1": {
    //   "version": "latest"
    // },

    // --- Conda (alternative Python env manager) ---
    // "ghcr.io/devcontainers/features/conda:2": {
    //   "version": "latest"
    // },

    // --- Anaconda (full distribution) ---
    // "ghcr.io/devcontainers/features/anaconda:1": {
    //   "version": "latest"
    // },

    // ===== CLIs & dev tools =====

    // --- Docker-in-Docker (run docker commands inside the codespace) ---
    // "ghcr.io/devcontainers/features/docker-in-docker:2": {
    //   "version": "latest",
    //   "moby": true
    // },

    // --- Docker outside-of-Docker (use the host's daemon) ---
    // "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
    //   "version": "latest"
    // },

    // --- Kubernetes tooling: kubectl, helm, minikube ---
    // "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {},

    // --- GitHub CLI (gh) ---
    // "ghcr.io/devcontainers/features/github-cli:1": {
    //   "version": "latest"
    // },

    // --- Git from source (newer than apt) ---
    // "ghcr.io/devcontainers/features/git:1": {
    //   "version": "latest"
    // },

    // --- Git LFS (large file support) ---
    // "ghcr.io/devcontainers/features/git-lfs:1": {},

    // --- Terraform + tflint + tfgrunt ---
    // "ghcr.io/devcontainers/features/terraform:1": {},

    // --- AWS CLI ---
    // "ghcr.io/devcontainers/features/aws-cli:1": {},

    // --- Azure CLI ---
    // "ghcr.io/devcontainers/features/azure-cli:1": {},

    // --- Google Cloud CLI (community) ---
    // "ghcr.io/dhoeric/features/google-cloud-cli:1": {},

    // --- Hugo (static site generator) ---
    // "ghcr.io/devcontainers/features/hugo:1": {},

    // --- Oryx (Microsoft's polyglot build system) ---
    // "ghcr.io/devcontainers/features/oryx:2": {},

    // --- PowerShell ---
    // "ghcr.io/devcontainers/features/powershell:2": {},

    // --- SSH server (for remote-into-codespace workflows) ---
    // "ghcr.io/devcontainers/features/sshd:1": {},

    // --- Common utilities (zsh, oh-my-zsh, sudo setup, etc.) ---
    // "ghcr.io/devcontainers/features/common-utils:2": {
    //   "installZsh": true,
    //   "configureZshAsDefaultShell": false,
    //   "installOhMyZsh": true
    // },

    // --- NVIDIA CUDA (GPU codespaces) ---
    // "ghcr.io/devcontainers/features/nvidia-cuda:3": {},

    // --- Light-weight desktop (VNC, for GUI apps) ---
    // "ghcr.io/devcontainers/features/desktop-lite:1": {}
  },

  "customizations": {
    "codespaces": {},
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "fish",
        "editor.formatOnSave": true
      },
      "extensions": [
        "ms-toolsai.jupyter",
        "ms-python.python",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "postAttachCommand": "nohup jupyter-lab --no-browser --port=8888 --ip=0.0.0.0 > /tmp/jupyter.log 2>&1 &",
  "forwardPorts": [8888]
}
