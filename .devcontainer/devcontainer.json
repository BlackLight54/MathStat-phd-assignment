{
  "name": "Research environment",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {

    // ===== Active: shell + tooling personalization =====
    "ghcr.io/meaningful-ooo/devcontainer-features/fish:2": {
      "fisher": false
    },
    "ghcr.io/eitsupi/devcontainer-features/jq-likes:2": {},
    "ghcr.io/guiyomh/features/just:0": {},

    // ===== Languages & runtimes available in Universal =====
    // Uncomment per project as needed.

    // --- Node.js (NestJS, frontend, tooling) ---
    // "ghcr.io/devcontainers/features/node:1": {
    //   "version": "lts",
    //   "nodeGypDependencies": true
    // },

    // --- Rust (cargo projects, Tamarin tooling helpers) ---
    // "ghcr.io/devcontainers/features/rust:1": {
    //   "version": "latest",
    //   "profile": "default"
    // },

    // --- Go (Hyperledger Fabric chaincode) ---
    // "ghcr.io/devcontainers/features/go:1": {
    //   "version": "latest"
    // },

    // --- Java (via SDKMAN!, for JVM-based research tools) ---
    // "ghcr.io/devcontainers/features/java:1": {
    //   "version": "21",
    //   "jdkDistro": "tem",
    //   "installGradle": true,
    //   "installMaven": true
